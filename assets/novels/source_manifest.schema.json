{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/changw98ic/n0vel/assets/novels/source_manifest.schema.json",
  "title": "Novel Writer Source Ledger Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAtMs", "entries"],
  "properties": {
    "schemaVersion": {
      "const": "source-ledger-v1"
    },
    "generatedAtMs": {
      "type": "integer",
      "minimum": 0
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/sourceLedgerEntry"}
    },
    "rootBindings": {
      "type": "array",
      "items": {"$ref": "#/$defs/sourceRootBinding"}
    }
  },
  "$defs": {
    "sourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"
    },
    "sourceLedgerEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "title",
        "licenseStatus",
        "allowedUses",
        "provenanceUri",
        "provenanceHash",
        "jurisdiction",
        "determinationDateMs",
        "attributionRequired",
        "reviewedBy",
        "reviewedAtMs"
      ],
      "properties": {
        "sourceId": {"$ref": "#/$defs/sourceId"},
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "creator": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 256
        },
        "licenseStatus": {
          "enum": [
            "publicDomain",
            "userOwned",
            "licensed",
            "restricted",
            "unknown"
          ]
        },
        "allowedUses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "abstractFeatures",
              "shortExcerpt",
              "fullContext",
              "calibration",
              "localRiskScan",
              "training"
            ]
          }
        },
        "provenanceUri": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "provenanceHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "jurisdiction": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64
        },
        "determinationDateMs": {
          "type": "integer",
          "minimum": 0
        },
        "excerptLimitChars": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "attributionRequired": {"type": "boolean"},
        "reviewedBy": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "reviewedAtMs": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"licenseStatus": {"const": "unknown"}},
            "required": ["licenseStatus"]
          },
          "then": {
            "properties": {
              "allowedUses": {"maxItems": 0},
              "excerptLimitChars": {"const": null}
            }
          }
        },
        {
          "if": {
            "properties": {"licenseStatus": {"const": "restricted"}},
            "required": ["licenseStatus"]
          },
          "then": {
            "properties": {
              "allowedUses": {
                "items": {"enum": ["abstractFeatures", "localRiskScan"]}
              },
              "excerptLimitChars": {"const": null}
            }
          }
        },
        {
          "if": {
            "properties": {
              "allowedUses": {"contains": {"const": "shortExcerpt"}}
            },
            "required": ["allowedUses"]
          },
          "then": {
            "required": ["excerptLimitChars"],
            "properties": {
              "excerptLimitChars": {"type": "integer", "minimum": 1}
            }
          }
        }
      ]
    },
    "sourceRootBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rootPath", "sourceIds"],
      "properties": {
        "rootPath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/sourceId"}
        },
        "contributionShares": {
          "type": "object",
          "propertyNames": {"$ref": "#/$defs/sourceId"},
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
